# Groq API Key (Get it free at console.groq.com) or whatever other
GROQ_API_KEY=your_groq_api_key_here

# Comma-separated list of local folders containing media to index
# Supports: books (.pdf, .epub, .mobi, .cbz) and videos (.mp4, .mkv, .avi) # you can add more in media_looker.py line 11 SUPPORTED_EXTENSIONS
# Example: MEDIA_DIRS=C:\Users\Name\Books,D:\Media\Shows
MEDIA_DIRS=C:\path\to\your\books,C:\path\to\your\videos
